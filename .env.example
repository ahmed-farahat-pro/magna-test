# ============================================================================
# AI Content Marketing Suite — Environment Variables
# Copy to .env.local for local dev:  cp .env.example .env.local
# In production, set every one of these in the Vercel Project → Settings → Environment Variables.
# NEVER commit .env / .env.local. Only this .env.example (with placeholders) is committed.
# ============================================================================

# --- LLM: Anthropic Claude (@anthropic-ai/sdk) --------------------------------
# Text generation + content improver. Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Images: OpenAI DALL·E 3 (openai sdk) -------------------------------------
# Image generation. Get from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Database: Neon serverless Postgres ---------------------------------------
# DATABASE_URL = POOLED connection (host contains "-pooler"). Used by the app at runtime.
#   pgbouncer=true disables prepared-statement caching (required for PgBouncer transaction pooling).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"
# DIRECT_URL = DIRECT connection (NO "-pooler" in host). Used ONLY by `prisma migrate deploy`.
#   Migrations need a direct, non-pooled connection to run DDL + advisory locks correctly.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require&connect_timeout=15"

# --- Image persistence: Vercel Blob (@vercel/blob) ----------------------------
# DALL·E URLs expire ~1h, so we request b64_json, re-upload to Blob, and store the permanent Blob URL.
# Auto-injected by Vercel when a Blob store is linked to the project; set manually for local dev.
# Get from Vercel → Storage → your Blob store → ".env.local" tab.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Anonymous session identity -----------------------------------------------
# httpOnly cookie holds an opaque sessionId (UUID). No auth/login.
# SESSION_COOKIE_NAME: name of the cookie. SESSION_SECRET: HMAC-signs the cookie so it can't be forged.
# Generate a secret with:  openssl rand -base64 32
SESSION_COOKIE_NAME="acms_sid"
SESSION_SECRET="replace-with-openssl-rand-base64-32-output"

# --- Optional: app base URL (handy for absolute links / OG tags) --------------
# Vercel provides VERCEL_URL automatically; set this only if you need a stable canonical.
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
